APP_NAME=Limoneo
APP_ENV=production
APP_KEY=
APP_DEBUG=false

# If true, production serves ONLY the under-construction landing.
# (Route file: routes/web.php)
LANDING_ONLY=false
APP_TIMEZONE=UTC
APP_URL=https://limoneo.com

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_URL=postgresql://neondb_owner:***@ep-round-unit-alr8cr3l.c-3.eu-central-1.aws.neon.tech:5432/neondb?sslmode=require

SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_STORE=file
QUEUE_CONNECTION=sync

FILESYSTEM_DISK=local

# Firebase (backend verify)
# FIREBASE_CA_BUNDLE=
# FIREBASE_HTTP_VERIFY=true

# Stripe
STRIPE_KEY=
STRIPE_SECRET=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

VITE_APP_NAME="${APP_NAME}"
