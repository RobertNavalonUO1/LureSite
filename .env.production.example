APP_NAME=Limoneo
APP_ENV=production
APP_KEY=
APP_DEBUG=false

# If true, production serves ONLY the under-construction landing.
# (Route file: routes/web.php)
LANDING_ONLY=false
APP_TIMEZONE=UTC
APP_URL=https://limoneo.com

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_URL=postgresql://neondb_owner:***@ep-round-unit-alr8cr3l.c-3.eu-central-1.aws.neon.tech:5432/neondb?sslmode=require

SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_STORE=file
QUEUE_CONNECTION=sync

FILESYSTEM_DISK=local

# Zoho Mail SMTP
MAIL_MAILER=smtp
MAIL_HOST=smtp.zoho.eu
MAIL_PORT=587
MAIL_SCHEME=smtp
MAIL_USERNAME=limoneo@limoneo.com
MAIL_PASSWORD=zoho_app_password_here
MAIL_FROM_ADDRESS=limoneo@limoneo.com
MAIL_FROM_NAME="${APP_NAME}"
MAIL_SUPPORT_ADDRESS=support@limoneo.com
MAIL_ORDERS_ADDRESS=orders@limoneo.com
MAIL_HELP_ADDRESS=help@limoneo.com
MAIL_EHLO_DOMAIN=limoneo.com

# Firebase (backend verify)
# FIREBASE_CA_BUNDLE=
# FIREBASE_HTTP_VERIFY=true

# Stripe
STRIPE_KEY=pk_test_replace_me
STRIPE_SECRET=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# PayPal
PAYPAL_CLIENT_ID=paypal_client_id_here
PAYPAL_CLIENT_SECRET=paypal_client_secret_here
PAYPAL_WEBHOOK_ID=paypal_webhook_id_here

# Social login (OAuth)
GOOGLE_CLIENT_ID=google_client_id_here
GOOGLE_CLIENT_SECRET=google_client_secret_here
GOOGLE_REDIRECT_URI=https://www.limoneo.com/auth/google/callback

FACEBOOK_CLIENT_ID=1574228981017382
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=https://www.limoneo.com/auth/facebook/callback

VITE_APP_NAME="${APP_NAME}"
